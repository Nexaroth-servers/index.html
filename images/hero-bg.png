.hero{
height:100vh;
background:
linear-gradient(rgba(0,0,0,.4),rgba(0,0,0,.85)),
url('hero-bg.png') center center / cover no-repeat;

display:flex;
justify-content:center;
align-items:center;
text-align:center;

animation:zoomHero 15s ease-in-out infinite alternate;
}

@keyframes zoomHero{
0%{
background-size:100%;
}
100%{
background-size:115%;
}
}
